{
  "name": "maplibre-font-pbf",
  "version": "0.1.0",
  "description": "Generate MapLibre-compatible glyph PBF files in memory from TTF font bytes.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "vendor",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.0.8",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
